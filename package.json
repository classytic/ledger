{
  "name": "@classytic/ledger",
  "version": "0.12.4",
  "description": "Production-grade double-entry accounting engine for MongoDB â€” schemas, reports, tax, multi-tenant",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./money": {
      "types": "./dist/money.d.mts",
      "import": "./dist/money.mjs",
      "default": "./dist/money.mjs"
    },
    "./reports": {
      "types": "./dist/reports/index.d.mts",
      "import": "./dist/reports/index.mjs",
      "default": "./dist/reports/index.mjs"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.mts",
      "import": "./dist/plugins/index.mjs",
      "default": "./dist/plugins/index.mjs"
    },
    "./constants": {
      "types": "./dist/constants/index.d.mts",
      "import": "./dist/constants/index.mjs",
      "default": "./dist/constants/index.mjs"
    },
    "./country": {
      "types": "./dist/country/index.d.mts",
      "import": "./dist/country/index.mjs",
      "default": "./dist/country/index.mjs"
    },
    "./exports": {
      "types": "./dist/exports/index.d.mts",
      "import": "./dist/exports/index.mjs",
      "default": "./dist/exports/index.mjs"
    },
    "./events": {
      "types": "./dist/events/index.d.mts",
      "import": "./dist/events/index.mjs",
      "default": "./dist/events/index.mjs"
    },
    "./bridges": {
      "types": "./dist/bridges/index.d.mts",
      "import": "./dist/bridges/index.mjs",
      "default": "./dist/bridges/index.mjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "accounting",
    "double-entry",
    "bookkeeping",
    "ledger",
    "journal",
    "chart-of-accounts",
    "financial-reports",
    "balance-sheet",
    "income-statement",
    "trial-balance",
    "general-ledger",
    "tax",
    "gst",
    "hst",
    "vat",
    "multi-tenant",
    "mongodb",
    "mongoose",
    "typescript"
  ],
  "author": "Classytic (https://github.com/classytic)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/classytic/ledger.git"
  },
  "peerDependencies": {
    "@classytic/mongokit": ">=3.14.0",
    "@classytic/primitives": ">=0.6.0",
    "@classytic/repo-core": ">=0.5.0",
    "mongoose": ">=9.6.2",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@classytic/dev-tools": "^0.2.0",
    "@classytic/mongokit": "^3.14.0",
    "@classytic/primitives": "^0.6.0",
    "@classytic/repo-core": "^0.5.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.4",
    "knip": "^6.4.1",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^9.6.2",
    "tsdown": "^0.21.8",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --project unit --project integration",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "test:watch": "vitest --project unit --project integration",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check src/ --write",
    "format": "biome format src/ --write",
    "check": "biome ci src/ --diagnostic-level=error",
    "knip": "knip",
    "push": "classytic-push",
    "smoke": "node scripts/smoke.mjs",
    "prepublishOnly": "npm run check && npm run build && npm run typecheck && npm test && npm run smoke",
    "release:tag": "node -e \"require('child_process').execSync('npm run push -- v'+require('./package.json').version,{stdio:'inherit'})\"",
    "release": "npm run push -- main && npm run release:tag && npm publish"
  }
}
